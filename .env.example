# Puerto del servidor (default 4010)
PORT=4010

# Ruta del archivo donde se persiste la clave del sellador (default ./.tsa-key.json).
# TSA_KEY_FILE=/var/lib/closer-click-signer/tsa-key.json

# Override: inyectar la clave privada por entorno (JWK EC P-256) en vez de archivo.
# Si se define, tiene prioridad sobre TSA_KEY_FILE. NO la commitees.
# TSA_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
